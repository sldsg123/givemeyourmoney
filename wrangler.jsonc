{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "givemeyourmoney",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-19",
  "assets": {
    "directory": "./docs",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
